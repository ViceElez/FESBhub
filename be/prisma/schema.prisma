generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     Int                      @id @default(autoincrement())
  email                  String                   @unique
  password               String
  firstName              String
  lastName               String?
  studij                 String?
  currentStudyYear       Int?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  isAdmin                Boolean                  @default(false)
  isVerified             Boolean                  @default(false)
  isEmailVerified        Boolean                  @default(false)
  Post                   Post[]
  CommentOnProffessor    CommentOnProffessor[]
  CommentOnSubject       CommentOnSubject[]
  File                   File[]
  Folder                 Folder[]
  RefreshToken           RefreshToken[]
  EmailVerificationToken EmailVerificationToken[]
}

model Subject {
  id                 Int                @id @default(autoincrement())
  title              String
  ratingExpectations Float              @default(0)
  ratingPracticality Float              @default(0)
  ratingDifficulty   Float              @default(0)
  idNositelja        Int
  idAuditornih       Int?
  comments           CommentOnSubject[]
  auditorne          Professor?         @relation("AuditorneRelation", fields: [idAuditornih], references: [id])
  nositelj           Professor          @relation("NositeljRelation", fields: [idNositelja], references: [id])
}

model Professor {
  id                Int                   @id @default(autoincrement())
  firstName         String
  lastName          String
  specialization    String
  education         String
  email             String
  rating            Float                 @default(0)
  comments          CommentOnProffessor[]
  SubjectsAsAuditor Subject[]             @relation("AuditorneRelation")
  SubjectAsNositelj Subject[]             @relation("NositeljRelation")
}

model CommentOnProffessor {
  id          Int       @id @default(autoincrement())
  content     String
  userId      Int
  professorId Int
  createdAt   DateTime  @default(now())
  rating      Float     @default(0)
  professor   Professor @relation(fields: [professorId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  verified    Boolean   @default(false)
}

model CommentOnSubject {
  id                Int      @id @default(autoincrement())
  content           String
  userId            Int
  subjectId         Int
  createdAt         DateTime @default(now())
  ratingExceptions  Float    @default(0)
  ratingPracicality Float    @default(0)
  ratingDiffuculty  Float    @default(0)
  subject           Subject  @relation(fields: [subjectId], references: [id])
  user              User     @relation(fields: [userId], references: [id])
  verified          Boolean  @default(false)
}

model Folder {
  id             Int      @id @default(autoincrement())
  name           String
  parentFolderId Int?
  userId         Int
  updatedAt      DateTime @updatedAt
  files          File[]   @relation("FileToFolder")
  parentFolder   Folder?  @relation("FolderHierarchy", fields: [parentFolderId], references: [id])
  subFolders     Folder[] @relation("FolderHierarchy")
  user           User     @relation(fields: [userId], references: [id])
}

model File {
  id             Int      @id @default(autoincrement())
  name           String
  parentFolderId Int?
  userId         Int
  url            String
  updatedAt      DateTime @updatedAt
  parentFolder   Folder?  @relation("FileToFolder", fields: [parentFolderId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
}

model Post {
  id        Int         @id @default(autoincrement())
  title     String
  content   String
  user      User        @relation(fields: [userId], references: [id])
  userId    Int
  verified  Boolean     @default(false)
  createdAt DateTime    @default(now())
  photos    PostImage[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  createdAt DateTime @default(now())
  expiresAt DateTime
  isrevoked Boolean  @default(false)
}

model PostImage {
  id     Int    @id @default(autoincrement())
  url    String
  post   Post   @relation(fields: [postId], references: [id])
  postId Int
}

model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  createdAt DateTime @default(now())
  expiresAt DateTime
}
